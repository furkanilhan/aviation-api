<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003" author="aviation">
        <createTable tableName="transportations">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="origin_location_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_transport_origin"
                             references="locations(id)"/>
            </column>
            <column name="destination_location_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_transport_destination"
                             references="locations(id)"/>
            </column>
            <column name="transportation_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="transportation_operating_days">
            <column name="transportation_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_operating_days_transport"
                             references="transportations(id)"/>
            </column>
            <column name="day" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>